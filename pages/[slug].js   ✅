import { useRouter } from 'next/router'
import { useEffect, useState } from 'react'

export default function DetailPost() {
  const router = useRouter()
  const { slug } = router.query

  const [post, setPost] = useState(null)

  useEffect(() => {
    if (!slug) return

    fetch(`https://script.google.com/macros/s/AKfycby4bOozGRubfyWgYmkgz8AaK4AA55nOFgsZ9vWWIVichcVz7JylPrmhZhIYAY1De5LM/exec?type=post&slug=${slug}`)
      .then(res => res.json())
      .then(data => setPost(data))
  }, [slug])

  if (!post) return <p>Loading...</p>
  if (post.error) return <p>Artikel tidak ditemukan</p>

  return (
    <div style={{ maxWidth: 800, margin: '40px auto' }}>
      <h1>{post.title}</h1>
      <p>{post.date} • {post.author}</p>
      <div dangerouslySetInnerHTML={{ __html: post.content }} />
    </div>
  )
}
