import { useRouter } from 'next/router'
import { useEffect, useState } from 'react'

export default function DetailPost() {
  const router = useRouter()
  const { slug } = router.query

  const [post, setPost] = useState(null)
  const [loading, setLoading] = useState(true)
  const [error, setError] = useState(false)

  useEffect(() => {
    if (!slug) return

    fetch(`https://script.googleusercontent.com/macros/s/AKfycby4bOozGRubfyWgYmkgz8AaK4AA55nOFgsZ9vWWIVichcVz7JylPrmhZhIYAY1De5LM/exec?type=post&slug=${slug}`)
      .then(res => res.json())
      .then(data => {
        if (data.status === "success") {
          setPost(data.data)
        } else {
          setError(true)
        }
      })
      .catch(() => setError(true))
      .finally(() => setLoading(false))
  }, [slug])

  // loading state
  if (loading) return <p style={{ padding: 20 }}>Loading...</p>

  // error state
  if (error || !post) {
    return <p style={{ padding: 20 }}>Artikel tidak ditemukan</p>
  }

  return (
    <div style={{ maxWidth: 800, margin: '40px auto', padding: 20 }}>
      <h1>{post.title}</h1>
      
      <p style={{ color: 'gray', marginBottom: 20 }}>
        {new Date(post.date).toLocaleDateString()} • {post.author}
      </p>

      <hr />

      <div
        dangerouslySetInnerHTML={{ __html: post.content }}
      />
    </div>
  )
}
